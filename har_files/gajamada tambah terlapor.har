            "text": "{\"metaData\":{\"pagination\":{\"size\":100,\"totalElements\":60,\"totalPages\":1,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":40},\"data\":[{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3A\",\"description\":\"Tidak setia dan taat sepenuhnya kepada pancasila, undang-undang dasar negara republik indonesia tahun 1945, negara, dan pemerintah\",\"id\":\"357bea9a1c84b6ba8b740055cc697dfa\",\"raw_pasal\":\"3a Tidak setia dan taat sepenuhnya kepada pancasila, undang-undang dasar negara republik indonesia tahun 1945, negara, dan pemerintah\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3B\",\"description\":\"Tidak mengutamakan kepentingan negara di atas kepentingan pribadi atau golongan serta menghindari segala sesuatu yang dapat merugikan kepentingan negara\",\"id\":\"6b2294285ca430272abb0d042682244c\",\"raw_pasal\":\"3b Tidak mengutamakan kepentingan negara di atas kepentingan pribadi atau golongan serta menghindari segala sesuatu yang dapat merugikan kepentingan negara\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3C\",\"description\":\"Tidak menjunjung tinggi kehormatan dan martabat negara, pemerintah, dan kepolisian negara republik indonesia\",\"id\":\"42af86d52d6845b7f1a7afd4cf8d7d15\",\"raw_pasal\":\"3c Tidak menjunjung tinggi kehormatan dan martabat negara, pemerintah, dan kepolisian negara republik indonesia\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3D\",\"description\":\"Tidak menyimpan rahasia negara dan/atau rahasia jabatan dengan sebaik-baiknya\",\"id\":\"345ab9b2b2fc374321c7c7916288d6a0\",\"raw_pasal\":\"3d Tidak menyimpan rahasia negara dan/atau rahasia jabatan dengan sebaik-baiknya\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3E\",\"description\":\"Tidak hormat-menghormati antar pemeluk agama\",\"id\":\"32af1f25c3c7079aff5cc69b48bc838f\",\"raw_pasal\":\"3e Tidak hormat-menghormati antar pemeluk agama\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3F\",\"description\":\"Tidak menjunjung tinggi hak asasi manusia\",\"id\":\"cd532baf52ef290668b165f0e168e47f\",\"raw_pasal\":\"3f Tidak menjunjung tinggi hak asasi manusia\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3G\",\"description\":\"Tidak menaati peraturan perundang-undangan yang berlaku, baik yang berhubungan dengan tugas kedinasan maupun yang berlaku secara umum\",\"id\":\"e951937df2d21f5ba2caa93697c42a80\",\"raw_pasal\":\"3g Tidak menaati peraturan perundang-undangan yang berlaku, baik yang berhubungan dengan tugas kedinasan maupun yang berlaku secara umum\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3H\",\"description\":\"Tidak melaporkan kepada atasannya apabila mengetahui ada hal yang dapat membahayakan dan/atau merugikan negara/ pemerintah\",\"id\":\"75fe82889b19128a92149254391b1f62\",\"raw_pasal\":\"3h Tidak melaporkan kepada atasannya apabila mengetahui ada hal yang dapat membahayakan dan/atau merugikan negara/ pemerintah\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3I\",\"description\":\"Tidak bersikap dan bertingkah laku sopan santun terhadap masyarakat\",\"id\":\"d3106047e040eacb12c19cd25441f9ff\",\"raw_pasal\":\"3i Tidak bersikap dan bertingkah laku sopan santun terhadap masyarakat\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"3J\",\"description\":\"Tidak berpakaian rapi dan pantas\",\"id\":\"8d38c2ef5591fd54b0c4e83ba1cdd014\",\"raw_pasal\":\"3j Tidak berpakaian rapi dan pantas\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4A\",\"description\":\"Tidak memberikan perlindungan, pengayoman, dan pelayanan dengan sebaik-baiknya kepada masyarakat\",\"id\":\"25595484ca82a17186c4052c8588cd81\",\"raw_pasal\":\"4a Tidak memberikan perlindungan, pengayoman, dan pelayanan dengan sebaik-baiknya kepada masyarakat\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4B\",\"description\":\"Tidak memperhatikan dan menyelesaikan dengan sebaik-baiknya laporan dan/atau pengaduan masyarakat\",\"id\":\"95d8531de2854c8d1c97ea04c8adddca\",\"raw_pasal\":\"4b Tidak memperhatikan dan menyelesaikan dengan sebaik-baiknya laporan dan/atau pengaduan masyarakat\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4C\",\"description\":\"Tidak menaati sumpah atau janji anggota kepolisian negara republik indonesia serta sumpah atau janji jabatan berdasarkan peraturan perundang-undangan yang berlaku\",\"id\":\"8a635365ed33a1c53a256572c605cca3\",\"raw_pasal\":\"4c Tidak menaati sumpah atau janji anggota kepolisian negara republik indonesia serta sumpah atau janji jabatan berdasarkan peraturan perundang-undangan yang berlaku\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4D\",\"description\":\"Tidak melaksanakan tugas sebaik-baiknya dengan penuh kesadaran dan rasa tanggung jawab\",\"id\":\"08bf323fbcd8f91dbfeb7db74e56812f\",\"raw_pasal\":\"4d Tidak melaksanakan tugas sebaik-baiknya dengan penuh kesadaran dan rasa tanggung jawab\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4E\",\"description\":\"Tidak memelihara dan meningkatkan keutuhan, kekompakan, persatuan, dan kesatuan kepolisian negara republik indonesia\",\"id\":\"620ce0e7bf74f5f27985e0ab4b5bdd97\",\"raw_pasal\":\"4e Tidak memelihara dan meningkatkan keutuhan, kekompakan, persatuan, dan kesatuan kepolisian negara republik indonesia\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4F\",\"description\":\"Tidak menaati segala peraturan perundang-undangan dan peraturan kedinasan yang berlaku\",\"id\":\"379927b721a11b51f75d409e5dae1fe7\",\"raw_pasal\":\"4f Tidak menaati segala peraturan perundang-undangan dan peraturan kedinasan yang berlaku\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4G\",\"description\":\"Tidak bertindak dan bersikap tegas serta berlaku adil dan bijaksana terhadap bawahannya\",\"id\":\"e67ec203879728d16918171d45e5b31c\",\"raw_pasal\":\"4g Tidak bertindak dan bersikap tegas serta berlaku adil dan bijaksana terhadap bawahannya\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4H\",\"description\":\"Tidak membimbing bawahannya dalam melaksanakan tugas\",\"id\":\"dd69375dc689007376f01a8925a1457d\",\"raw_pasal\":\"4h Tidak membimbing bawahannya dalam melaksanakan tugas\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4I\",\"description\":\"Tidak memberikan contoh dan teladan yang baik terhadap bawahannya\",\"id\":\"b7caa1429f2637ec50cd9a159d60d6b8\",\"raw_pasal\":\"4i Tidak memberikan contoh dan teladan yang baik terhadap bawahannya\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4J\",\"description\":\"Tidak mendorong semangat bawahannya untuk meningkatkan prestasi kerja\",\"id\":\"a70aaf572585a31537fefced9b977b9f\",\"raw_pasal\":\"4j Tidak mendorong semangat bawahannya untuk meningkatkan prestasi kerja\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4K\",\"description\":\"Tidak memberikan kesempatan kepada bawahannya untuk mengembangkan karier\",\"id\":\"33a072a46b026aec0f739be9485b8153\",\"raw_pasal\":\"4k Tidak memberikan kesempatan kepada bawahannya untuk mengembangkan karier\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4L\",\"description\":\"Tidak menaati perintah kedinasan yang sah dari atasan yang berwenang\",\"id\":\"ef6410b5d2cc89dc7d5c68d63f7f3b63\",\"raw_pasal\":\"4l Tidak menaati perintah kedinasan yang sah dari atasan yang berwenang\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4M\",\"description\":\"Tidak menaati ketentuan jam kerja\",\"id\":\"e8f0b9c361efaa26acf8a427599ae581\",\"raw_pasal\":\"4m Tidak menaati ketentuan jam kerja\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4N\",\"description\":\"Tidak menggunakan dan memelihara barang milik dinas dengan sebaik-baiknya\",\"id\":\"fa34844acbbc31333a2d979ceb8f816a\",\"raw_pasal\":\"4n Tidak menggunakan dan memelihara barang milik dinas dengan sebaik-baiknya\"},{\"type\":\"PPRI NOMOR 2 TAHUN 2003\",\"kode_pasal\":\"4O\",\"description\":